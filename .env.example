# API base URL – Kalpsite uses this for all backend calls (login, RPCs, etc.).
# Set per environment; do not commit production URLs if they are secret.
#
# Local development (use .env.local, gitignored):
#   NAKAMA_URL=http://127.0.0.1:80
#   or  NAKAMA_URL=http://localhost:80
#
# Production (set in your hosting dashboard, e.g. Vercel → Settings → Environment Variables):
#   NAKAMA_URL=https://api.kalpixsoftware.com
#
NAKAMA_URL=http://127.0.0.1:80
NAKAMA_SERVER_KEY=defaultkey

# Admin: no registration on Kalpsite. Create admin accounts manually in Nakama (Dashboard / API Explorer / Postman)
# and set is_admin: true in account metadata. Then log in here with that account’s email and password.
