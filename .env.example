# Nakama game server URL (used for admin session and RPCs)
NAKAMA_URL=http://127.0.0.1:7350
NAKAMA_SERVER_KEY=defaultkey
# For admin register/verify RPCs (auth/register_email, auth/verify_registration_otp). Must match backend NAKAMA_RUNTIME_HTTP_KEY (default: defaulthttpkey).
NAKAMA_HTTP_KEY=defaulthttpkey

# Kalpsite admin login (separate from Nakama Console – your own username/password)
KALPSITE_ADMIN_USERNAME=admin
KALPSITE_ADMIN_PASSWORD=change-me

# Admin game user: email/password of a Nakama user with is_admin: true in metadata.
# Login uses these to obtain a game session so admin RPCs run as this user.
NAKAMA_ADMIN_EMAIL=admin@example.com
NAKAMA_ADMIN_PASSWORD=game-user-password
