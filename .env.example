# Backend gateway URL – Kalpsite uses this for all backend calls (login, admin RPCs).
# Set per environment. Use .env.local for local (gitignored); set in Vercel for production.
#
# Local:  KALPIX_API_URL=http://localhost
# Prod:  KALPIX_API_URL=https://api.kalpixsoftware.com
#
KALPIX_API_URL=http://localhost

# WebSocket URL for bot chat real-time (reactions, new messages). Optional – if unset, bot chat works without live updates.
# Local:  NEXT_PUBLIC_KALPIX_WS_URL=ws://localhost/ws
# Prod:  NEXT_PUBLIC_KALPIX_WS_URL=wss://api.kalpixsoftware.com/ws
# NEXT_PUBLIC_KALPIX_WS_URL=

# Local dev only: skip re-uploading spine assets to R2 from the admin sync page.
# The spine files already live on the shared R2 bucket, so a fresh local DB just needs the
# catalog to point at them. When true, "Upload Spine Assets" skips the R2 PUT and reuses the
# deterministic public URL (avatars/{slug}/spine/{fileName}). Leave unset/false in production.
# NEXT_PUBLIC_SKIP_R2_UPLOAD=true

# Admin: no registration on Kalpsite. Create admin accounts manually in the Kalpix backend
# and set is_admin: true in account metadata. Then log in here with that account's email and password.
