# Nakama game server via Nginx (port 80). Used for authenticated RPCs and session checks.
NAKAMA_URL=http://127.0.0.1:80
NAKAMA_SERVER_KEY=defaultkey

# Base URL for unauthenticated auth RPCs (Nginx adds http_key). Use same host as Nginx (e.g. port 80).
AUTH_PROXY_URL=http://localhost

# Kalpsite admin login: use the same email/password as your verified game account (Postman/Plazy).
# Backend ADMIN_EMAIL (kalpix-backend .env) must match so the user gets is_admin in metadata.
KALPSITE_ADMIN_EMAIL=admin@example.com
KALPSITE_ADMIN_PASSWORD=change-me
